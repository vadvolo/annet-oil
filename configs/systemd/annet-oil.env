# Annet Oil Service Environment Configuration
# This file should be placed at /etc/annet-oil/annet-oil.env

# Basic Configuration
ANNET_OIL_CONFIG=/opt/annet-oil/configs/config.yaml
ANNET_OIL_STORAGE=/opt/annet-oil/storage
ANNET_OIL_LOG_LEVEL=info

# Server Configuration
ANNET_OIL_API_PORT=8080
ANNET_OIL_API_BIND=0.0.0.0
ANNET_OIL_SSH_PORT=22
ANNET_OIL_SSH_BIND=0.0.0.0

# API Authentication (change this to a secure token)
ANNET_OIL_API_TOKEN=your-secret-token-here

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_API_VERSION=1.41
DOCKER_TLS_VERIFY=false

# MCP Server Configuration (for mcp-annet-oil service)
MCP_SERVER_NAME=annet-oil
MCP_SERVER_VERSION=1.0.0

# Annet Oil API endpoint for MCP server
ANNET_OIL_API_URL=http://localhost:8080

# Node.js Configuration (for mcp-annet-oil service)
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=2048

# Logging
LOG_FORMAT=json
LOG_OUTPUT=stdout